# Copie ce fichier en .env puis personnalise les valeurs.

# Secret JWT — OBLIGATOIRE. Génère-le par ex. avec :
#   openssl rand -hex 48
JWT_SECRET=

# Mot de passe PostgreSQL (docker-compose)
DB_PASSWORD=change-me

# URL du frontend (pour le CORS de l'API)
FRONTEND_URL=http://localhost:3000

# URL de l'API vue depuis le navigateur des utilisateurs
# (si tu héberges sur un serveur : https://api.ton-domaine.fr)
API_URL=http://localhost:8080

# Code d'invitation demandé à l'inscription (vide = inscription libre).
# Recommandé dès que l'instance est accessible hors du réseau local.
INVITE_CODE=

# Webhook Slack ou Teams (format {"text": "..."}) pour le rappel de séance.
# Vide = pas de rappel.
WEBHOOK_URL=

# Cron du rappel (défaut : 11 h 45 du lundi au vendredi, heure de Paris)
REMINDER_CRON=0 45 11 * * MON-FRI
